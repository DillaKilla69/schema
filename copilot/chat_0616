A good shape is:

```python
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Build CZML from database inputs.")
    parser.add_argument("db_name", help="Postgres/MySQL database name")
    parser.add_argument("repetition_count", type=int, help="Repetition count used by the legacy pipeline")
    parser.add_argument(
        "--output",
        default="output.czml",
        help="Path to write the generated CZML file",
    )
    parser.add_argument(
        "--cesium-script",
        default="cesium.py",
        help="Path to the legacy cesium builder script",
    )
    return parser.parse_args()


def build_config(args: argparse.Namespace) -> dict:
    return {
        "db_name": args.db_name,
        "repetition_count": args.repetition_count,
        "output_czml": str(Path(args.output).resolve()),
        "sql_dir": str((Path(__file__).parent / "sql").resolve()),
        "legacy_mode": True,
    }


def run_cesium_builder(config: dict, cesium_script: str) -> None:
    command = [
        sys.executable,
        cesium_script,
        "--config",
        json.dumps(config),
    ]
    completed = subprocess.run(command, check=True, capture_output=True, text=True)
    if completed.stdout:
        print(completed.stdout)
    if completed.stderr:
        print(completed.stderr, file=sys.stderr)


def main() -> None:
    args = parse_args()
    config = build_config(args)
    run_cesium_builder(config, args.cesium_script)


if __name__ == "__main__":
    main()
```

